Options -Indexes
RewriteEngine On
RewriteBase /

# Force HTTPS (Optional, depending on environment)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Pretty URLs for sport pages
RewriteRule ^sport/([a-z-]+)/?$ sport.php?slug=$1 [L,QSA]

# Block admin from search engines
<IfModule mod_headers.c>
  <FilesMatch "^admin">
    Header set X-Robots-Tag "noindex, nofollow"
  </FilesMatch>
</IfModule>

# Protect config and db
<FilesMatch "^(config\.php|sportingrank\.sqlite)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Compress
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
